# Database (pooled connection, used at runtime by the Prisma driver adapter)
DATABASE_URL="postgresql://user:password@host:5432/dbname?sslmode=require"
# Database (direct/unpooled connection, used by Prisma Migrate via prisma.config.ts)
DATABASE_URL_UNPOOLED="postgresql://user:password@host:5432/dbname?sslmode=require"

# Better Auth - Google OAuth
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# Better Auth - GitHub OAuth
GITHUB_CLIENT_ID=""
GITHUB_CLIENT_SECRET=""

# Better Auth - Secret
BETTER_AUTH_SECRET=""

# Pusher - Realtime (server)
PUSHER_APP_ID=""
PUSHER_KEY=""
PUSHER_SECRET=""
PUSHER_CLUSTER=""
# Pusher - Realtime (browser client, must mirror PUSHER_KEY / PUSHER_CLUSTER)
NEXT_PUBLIC_PUSHER_KEY=""
NEXT_PUBLIC_PUSHER_CLUSTER=""

# AI Providers (Phase 3+)
GROQ_API_KEY=""
GEMINI_API_KEY=""
# AI Providers - daily quota per workspace (Phase D, Feature 018)
AI_DAILY_LIMIT="50"

# Resend - transactional email (Phase D, Feature 024)
RESEND_API_KEY=""
RESEND_FROM="Axiom <noreply@axiom.dev>"

# Sentry - Error monitoring (Phase C, Feature 010)
SENTRY_DSN=""
SENTRY_ORG=""
SENTRY_PROJECT=""
NEXT_PUBLIC_SENTRY_DSN=""

# Public app URL - used for SEO metadata/OG tags/sitemap, email links, webhook docs, API reference (Phase C/D)
NEXT_PUBLIC_APP_URL="https://axiom-kanban.vercel.app"
